import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.sql.*;
public class Slip12Q2 extends JFrame {
    JTable table; DefaultTableModel model;
    public Slip12Q2() throws SQLException {
        try(Connection con=DriverManager.getConnection("jdbc:mysql://localhost/db","root","");
            Statement st=con.createStatement()){
            st.execute("create table if not exists PROJECT(project_id int primary key, project_name varchar(20), project_description varchar(100), project_status varchar(10))");
            st.executeUpdate("insert into PROJECT values(1,'A','desc1','Active'),(2,'B','desc2','Inactive')");
            ResultSet rs = st.executeQuery("select * from PROJECT");
            model = new DefaultTableModel(new String[]{"ID","Name","Desc","Status"},0);
            while(rs.next()) model.addRow(new Object[]{rs.getInt(1),rs.getString(2),rs.getString(3),rs.getString(4)});
            table = new JTable(model);
            add(new JScrollPane(table));
            setSize(500,300); setVisible(true);
        }
    }
    public static void main(String[] args) throws SQLException { new Slip12Q2(); }
}
