class PrintThread extends Thread {
    String msg; int times;
    PrintThread(String msg,int times) { this.msg=msg; this.times=times; }
    public void run() { for(int i=0;i<times;i++) System.out.println(msg); }
}
public class Slip8Q1 {
    public static void main(String[] args) {
        new PrintThread("COVID19",10).start();
        new PrintThread("LOCKDOWN2020",20).start();
        new PrintThread("VACCINATED2021",30).start();
    }
}

