import javax.swing.*;
import java.awt.*;
public class Slip4Q1 extends JFrame implements Runnable {
    JLabel label; boolean visible=true;
    public Slip4Q1() {
        label=new JLabel("BLINKING TEXT",SwingConstants.CENTER);
        add(label); setSize(300,200); setVisible(true);
        new Thread(this).start();
    }
    public void run() {
        while(true) {
            label.setVisible(visible=!visible);
            try{Thread.sleep(500);}catch(Exception e){}
        }
    }
    public static void main(String[] args) { new Slip4Q1(); }
}

import java.util.*;
public class Slip4Q2 {
    static Map<String,String> map = new HashMap<>();
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        map.put("Mumbai","022"); // sample
        while(true) {
            System.out.println("1.Add 2.Remove 3.Search 4.Exit");
            int ch=sc.nextInt(); sc.nextLine();
            if(ch==1) { String city=sc.nextLine(), code=sc.nextLine(); map.putIfAbsent(city,code); }
            else if(ch==2) { map.remove(sc.nextLine()); }
            else if(ch==3) { System.out.println(map.get(sc.nextLine())); }
            else break;
        }
    }
}
