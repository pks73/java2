package com.mycompany.javaslip;

public class Slip1_Q1 {
    public static void main(String[] args) {
        Thread t = new Thread(() -> {
            while (true) {
                for (char ch = 'A'; ch <= 'Z'; ch++) {
                    System.out.print(ch + " ");
                }
                System.out.println("\n2 seconds are passed....");
                try {
                    Thread.sleep(2000);
                } catch (InterruptedException e) {
                    System.out.println("Thread interrupted");
                }
            }
        });
        t.start();
    }
}

package com.mycompany.prac1;

import java.awt.*;
import java.awt.event.*;
import java.sql.*;
import javax.swing.*;

public class Slip1_Q2 {
    
    private JFrame frame;
    private JTextField eno, ename, desig, sal;
    private JButton clear, insert;
    private Connection conn;

    public Slip1_Q2() throws SQLException {
        // Database connection
        conn = DriverManager.getConnection(
            "jdbc:postgresql://localhost:5432/postgres",
            "postgres",
            "bhalchandra"
        );

        // Swing UI setup
        frame = new JFrame("Employee App");
        frame.setSize(400, 200);
        frame.setLayout(new GridLayout(5, 2));
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

        eno = new JTextField();
        ename = new JTextField();
        desig = new JTextField();
        sal = new JTextField();

        frame.add(new JLabel("Eno."));
        frame.add(eno);
        frame.add(new JLabel("EName"));
        frame.add(ename);
        frame.add(new JLabel("Designation"));
        frame.add(desig);
        frame.add(new JLabel("Salary"));
        frame.add(sal);

        clear = new JButton("Clear");
        insert = new JButton("Insert");

        // Insert button action
        insert.addActionListener(e -> insertEmployee());
        
        // Clear button action
        clear.addActionListener(e -> {
            eno.setText("");
            ename.setText("");
            desig.setText("");
            sal.setText("");
        });

        frame.add(insert);
        frame.add(clear);
        frame.setVisible(true);
    }

    private void insertEmployee() {
        String sql = "INSERT INTO emp VALUES (?, ?, ?, ?)";
        try (PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setInt(1, Integer.parseInt(eno.getText()));
            ps.setString(2, ename.getText());
            ps.setString(3, desig.getText());
            ps.setFloat(4, Float.parseFloat(sal.getText()));
            ps.executeUpdate();
            JOptionPane.showMessageDialog(frame, "Record inserted successfully");
        } catch (SQLException | NumberFormatException ex) {
            JOptionPane.showMessageDialog(frame, "Error: " + ex.getMessage());
        }
    }

    public static void main(String[] args) throws SQLException {
        new Slip1_Q2();
    }
}
